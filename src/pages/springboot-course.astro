<!-- ══════════════════════════════════════════════════════════════
     SCRIPT — define:vars pasa la data del frontmatter al cliente
════════════════════════════════════════════════════════════════ -->
<script
  define:vars={{
    weeks,
    MILESTONES,
    completedWeeks,
    totalWeeks,
    progressPercent,
  }}
>
  // ── EXP bar animation ──────────────────────────────────────
  setTimeout(() => {
    const fill = document.getElementById("exp-fill");
    const label = document.getElementById("pct-label");
    if (fill) fill.style.width = progressPercent + "%";

    let n = 0;
    const iv = setInterval(() => {
      n++;
      if (n >= completedWeeks) {
        n = completedWeeks;
        clearInterval(iv);
      }
      if (label) label.textContent = `${n} / ${totalWeeks} semanas`;
    }, 120);
  }, 350);

  // ── Render week cards ──────────────────────────────────────
  function renderWeeks(filter) {
    const stack = document.getElementById("weeks-stack");
    const counter = document.getElementById("week-count");
    if (!stack) return;

    stack.innerHTML = "";
    const list =
      filter === "all" ? weeks : weeks.filter((w) => w.ms === filter);
    if (counter)
      counter.textContent = `${list.length} semana${list.length !== 1 ? "s" : ""}`;

    list.forEach((w) => {
      const ms = MILESTONES[w.ms];
      const card = document.createElement("div");
      card.className = "week-card" + (w.done ? " done" : "");

      // Stripe de color del milestone
      const stripe = document.createElement("div");
      stripe.className = "week-stripe";
      stripe.style.background = w.done ? ms.color : "var(--border)";
      card.appendChild(stripe);

      card.innerHTML += `
      <div class="week-head">
        <div class="week-num mono">W${w.n}</div>
        <div class="week-info">
          <div class="week-ms-row">
            <span class="week-ms-chip mono"
              style="background:${ms.color}20;color:${ms.color}">${w.ms}</span>
            <span class="week-ms-label">${ms.label}</span>
          </div>
          <div class="week-name">${w.name}</div>
          <div class="week-date mono">${w.date}</div>
        </div>
        <div class="pokeball" aria-hidden="true"></div>
        <div class="week-arrow" aria-hidden="true">▾</div>
      </div>
      <div class="week-body" role="region">
        <div class="week-body-inner">
          <p>${w.detail}</p>
          <div class="week-body-footer">
            <span class="ver-tag mono">${w.ver}</span>
            ${
              w.done
                ? `<a class="gh-link" href="https://github.com/lgzarturo/springboot-course/releases/tag/${w.ver}"
                    target="_blank" rel="noopener noreferrer">ver release →</a>`
                : ""
            }
          </div>
        </div>
      </div>
    `;

      card.addEventListener("click", () => {
        const isOpen = card.classList.toggle("open");
        const arrow = card.querySelector(".week-arrow");
        if (arrow) arrow.textContent = isOpen ? "▴" : "▾";
      });

      stack.appendChild(card);
    });
  }
  renderWeeks("all");

  // ── Gym badge filter ───────────────────────────────────────
  document.getElementById("badge-filter")?.addEventListener("click", (e) => {
    const btn = e.target.closest(".gym-badge");
    if (!btn) return;

    document.querySelectorAll(".gym-badge").forEach((b) => {
      b.classList.remove("active");
      b.setAttribute("aria-pressed", "false");
    });
    btn.classList.add("active");
    btn.setAttribute("aria-pressed", "true");
    renderWeeks(btn.dataset.ms);
  });

  // ── Scroll reveal ──────────────────────────────────────────
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          io.unobserve(e.target);
        }
      });
    },
    { threshold: 0.07 },
  );
  document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
</script>
