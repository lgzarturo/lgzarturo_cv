---
// src/pages/springboot-course.astro
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

import { completedWeeks, totalWeeks } from "../data/course";

const title = "Curso Gamificado Spring Boot + Kotlin | Arturo López";
const description =
  "Aprende Spring Boot 3.x con Kotlin, arquitectura hexagonal y TDD. Retos reales de hotelería y ecommerce. Sin relleno.";
const pendingWeeks = totalWeeks - completedWeeks;
---

<BaseLayout
  title="Curso Gamificado Spring Boot + Kotlin | Arturo López Gómez"
  description="Aprende Spring Boot con arquitectura hexagonal y TDD en una experiencia gamificada. Ejemplos reales de hotelería y ecommerce."
  canonical="https://lgzarturo.com/springboot-course"
>
  <head>
    <meta
      name="description"
      content="Curso gamificado de Spring Boot con arquitectura hexagonal, TDD y ejemplos reales de hotelería y ecommerce. Aprende programación con una narrativa inspirada en Pokémon. ¡Únete a la comunidad de desarrolladores!"
    />
    <meta
      name="keywords"
      content="Spring Boot, curso gamificado, arquitectura hexagonal, TDD, Pokémon, hotelería, ecommerce, comunidad de desarrolladores, programación, Java, backend, buenas prácticas, desarrollo de software"
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://lgzarturo.dev/springboot-course" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Curso Gamificado Spring Boot: Aprende con Pokémon, Hotelería y Ecommerce"
    />
    <meta
      property="og:description"
      content="Aprende Spring Boot, arquitectura hexagonal y TDD con una experiencia gamificada inspirada en Pokémon, hotelería y ecommerce. ¡Únete a la comunidad de desarrolladores!"
    />
    <meta property="og:url" content="https://lgzarturo.dev/springboot-course" />
    <meta
      property="og:image"
      content="https://raw.githubusercontent.com/lgzarturo/arthurolg-blog-posts/refs/heads/main/articles/images/el-legado-del-desarrollador.webp"
    />
    <meta
      property="og:image:alt"
      content="Curso Gamificado Spring Boot - Pokémon, Hotelería y Ecommerce"
    />
    <meta property="og:site_name" content="Arturo López Gómez" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Curso Gamificado Spring Boot: Aprende con Pokémon, Hotelería y Ecommerce"
    />
    <meta
      name="twitter:description"
      content="Aprende Spring Boot, arquitectura hexagonal y TDD con una experiencia gamificada inspirada en Pokémon, hotelería y ecommerce. ¡Únete a la comunidad de desarrolladores!"
    />
    <meta
      name="twitter:image"
      content="https://raw.githubusercontent.com/lgzarturo/arthurolg-blog-posts/refs/heads/main/articles/images/el-legado-del-desarrollador.webp"
    />
    <meta
      name="twitter:image:alt"
      content="Curso Gamificado Spring Boot - Pokémon, Hotelería y Ecommerce"
    />
    <script type="application/ld+json" is:raw>
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "Curso Gamificado de Spring Boot: Aprende con Pokémon, Hotelería y Ecommerce",
        "description": "Curso gamificado de Spring Boot con arquitectura hexagonal, TDD y ejemplos reales de hotelería y ecommerce. Aprende programación con una narrativa inspirada en Pokémon. Únete a la comunidad de desarrolladores.",
        "provider": {
          "@type": "Person",
          "name": "Arturo López Gómez",
          "url": "https://lgzarturo.dev"
        },
        "educationalCredentialAwarded": "Certificado de participación y dominio en Spring Boot, arquitectura hexagonal y TDD.",
        "image": "https://raw.githubusercontent.com/lgzarturo/arthurolg-blog-posts/refs/heads/main/articles/images/el-legado-del-desarrollador.webp",
        "keywords": [
          "Spring Boot",
          "curso gamificado",
          "arquitectura hexagonal",
          "TDD",
          "Pokémon",
          "hotelería",
          "ecommerce",
          "comunidad de desarrolladores",
          "Java",
          "backend",
          "buenas prácticas",
          "desarrollo de software"
        ],
        "url": "https://lgzarturo.dev/springboot-course"
      }
    </script>
  </head>
  <link is:raw rel="preconnect" href="https://fonts.googleapis.com" />
  <link is:raw rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    is:raw
    href="https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400..700&display=swap"
    rel="stylesheet"
  />
  <Header title="Arturo López" />
  <style is:inline>
    /* Fondo animado pixel art */
    body,
    .pixel-bg {
      background: #181c1f
        url("https://www.transparenttextures.com/patterns/pixel-weave.png");
      min-height: 100vh;
      position: relative;
      z-index: 0;
    }
    .pixel-bg::before {
      content: "";
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background:
        repeating-linear-gradient(135deg, #2aff6a 0 2px, transparent 2px 20px),
        repeating-linear-gradient(45deg, #00e0ff 0 2px, transparent 2px 20px);
      opacity: 0.08;
      z-index: 1;
      pointer-events: none;
      animation: pixel-move 20s linear infinite;
    }
    @keyframes pixel-move {
      0% {
        background-position:
          0 0,
          0 0;
      }
      100% {
        background-position:
          200px 200px,
          -200px -200px;
      }
    }
    /* Animaciones sutiles */
    @keyframes pulse-slow {
      0%,
      100% {
        opacity: 1;
      }
      50% {
        opacity: 0.7;
      }
    }
    .pulse-slow {
      animation: pulse-slow 4s ease-in-out infinite;
    }
    /* Estilo tipo videojuego pixel art */
    .pixel-font {
      font-family: "Pixelify Sans", cursive;
      font-optical-sizing: auto;
      font-style: normal;
      letter-spacing: 1px;
      text-shadow:
        2px 2px 0 #222,
        4px 4px 0 #2aff6a;
    }
    /* Bordes pixelados */
    .pixel-border {
      border: 4px solid #2aff6a;
      box-shadow:
        0 0 0 4px #222,
        0 0 16px 2px #2aff6a44;
      border-radius: 0.5rem;
    }
    /* Botón retro */
    .btn-retro {
      font-family: "Pixelify Sans", cursive;
      background: linear-gradient(90deg, #2aff6a 0%, #00e0ff 100%);
      color: #181c1f;
      border: 3px solid #fff;
      box-shadow:
        0 0 0 3px #2aff6a,
        0 0 12px 2px #00e0ff99;
      text-shadow: 1px 1px 0 #fff;
      transition:
        background 0.2s,
        color 0.2s,
        box-shadow 0.2s;
    }
    .btn-retro:hover {
      background: #181c1f;
      color: #2aff6a;
      box-shadow:
        0 0 0 3px #00e0ff,
        0 0 24px 4px #2aff6a99;
    }
    /* Secciones como "pantallas" de videojuego */
    .level-section {
      background: rgba(24, 28, 31, 0.95);
      border: 4px solid #00e0ff;
      box-shadow:
        0 0 0 4px #2aff6a,
        0 0 24px 2px #00e0ff44;
      border-radius: 0.5rem;
      margin-bottom: 2rem;
    }
    /* Títulos con efecto glow */
    .glow-h1 {
      color: #fff;
      text-shadow:
        0 0 8px #00e0ff,
        0 0 16px #2aff6a;
    }
    .glow-title {
      color: #2aff6a;
      text-shadow:
        0 0 8px #00e0ff,
        0 0 16px #2aff6a;
    }
    /* Responsive fix para pixel font */
    @media (max-width: 600px) {
      .pixel-font {
        font-size: 1.1rem !important;
      }
    }

    ul.cherry-list {
      list-style-image: url("/cherries-icon.svg");
      list-style-position: inside;
      list-style-type: none; /* evita el disco si usas imagen */
    }

    ul.cherry-list li {
      display: flex;
      align-items: center;
      gap: 0.5em; /* espacio entre ícono y texto */
    }

    ul.cherry-list {
      list-style: none; /* desactiva el ícono automático */
    }

    ul.cherry-list li::before {
      content: "";
      display: inline-block;
      width: 1.5em;
      height: 1.5em;
      background-image: url("/cherries-icon.svg");
      background-size: contain;
      background-repeat: no-repeat;
      margin-right: 0.5em;
    }

    .text-outline {
      -webkit-text-stroke: 1px #2b2a2a;
    }
  </style>
  <div
    class="flex flex-col min-h-screen pixel-bg md:p-20"
    itemscope
    itemtype="https://schema.org/Course"
  >
    <!-- Header -->
    <header
      class="relative z-10 flex flex-col items-center p-20 mt-20 shadow-lg pixel-border bg-gradient-to-r from-green-400 via-blue-700 to-purple-700 shadow-xl/30"
      itemprop="provider"
      itemscope
      itemtype="https://schema.org/Person"
    >
      <h1
        class="mb-8 font-sans text-3xl font-extrabold text-center sm:text-4xl md:text-6xl drop-shadow-lg animate-pulse glow-h1 text-shadow-2xs text-shadow-sky-300 md:pixel-font text-outline"
        itemprop="name"
      >
        Curso Gamificado de <span class="text-green-300">Spring Boot</span> con <span
          class="text-blue-300">Arquitectura Hexagonal</span
        > y <span class="text-yellow-300">TDD</span>
      </h1>
      <p
        class="max-w-4xl text-lg text-center text-white md:text-2xl drop-shadow-md"
        itemprop="description"
      >
        <strong
          >Aprende <span class="text-green-300">Spring Boot</span>, <span
            class="text-blue-300">buenas prácticas</span
          > y <span class="text-yellow-300">arquitectura hexagonal</span> con <span
            class="text-pink-400">TDD</span
          ></strong
        > en una experiencia única y divertida. Vive una <strong
          >historia gamificada inspirada en <span class="text-pink-300"
            >Pokémon</span
          ></strong
        >, resolviendo retos reales de <strong>hotelería</strong> y <strong
          >ecommerce</strong
        >. ¡Conviértete en un <span class="text-green-400"
          >maestro desarrollador</span
        > y únete a la <span class="text-blue-400">comunidad</span>!
      </p>
      <nav aria-label="Navegación de secciones">
        <ul class="flex flex-wrap justify-center gap-4 mt-4">
          <li>
            <a
              href="#que-es"
              class="text-green-300 underline hover:text-green-400">¿Qué es?</a
            >
          </li>
          <li>
            <a
              href="#gamificacion"
              class="text-pink-300 underline hover:text-pink-400"
              >Gamificación</a
            >
          </li>
          <li>
            <a
              href="#ejemplos"
              class="text-blue-300 underline hover:text-blue-400">Ejemplos</a
            >
          </li>
          <li>
            <a
              href="#fundamento"
              class="text-purple-300 underline hover:text-purple-400"
              >Fundamento</a
            >
          </li>
          <li>
            <a
              href="#beneficios"
              class="text-yellow-300 underline hover:text-yellow-400"
              >Beneficios</a
            >
          </li>
          <li>
            <a
              href="#participa"
              class="text-red-300 underline hover:text-red-400">Participa</a
            >
          </li>
        </ul>
      </nav>
      <a href="#participa" class="px-8 py-3 mt-6 btn-retro"
        >¡Únete y participa en el curso de Spring Boot!</a
      >
      <meta
        itemprop="image"
        content="https://raw.githubusercontent.com/lgzarturo/arthurolg-blog-posts/refs/heads/main/articles/images/el-legado-del-desarrollador.webp"
      />
      <meta itemprop="url" content="https://lgzarturo.dev/springboot-course" />
      <span itemprop="name" class="hidden">Arturo López Gómez</span>
      <meta itemprop="url" content="https://lgzarturo.dev" />
    </header>

    <main class="container z-10 flex-grow px-6 py-12 mx-auto space-y-20">
      <!-- ¿Qué es este curso? -->
      <section
        id="que-es"
        class="max-w-5xl p-8 mx-auto level-section"
        aria-labelledby="que-es-titulo"
      >
        <h2
          id="que-es-titulo"
          class="inline-block mb-4 text-3xl font-bold border-b-4 border-yellow-400 pixel-font glow-title"
        >
          ¿Qué es este <span class="text-green-300"
            >curso gamificado de Spring Boot</span
          >?
        </h2>
        <p class="text-lg leading-relaxed text-white">
          Este <strong>curso online de Spring Boot</strong> es una experiencia educativa
          innovadora que combina el <strong>aprendizaje técnico</strong> con una
          <strong>narrativa gamificada</strong> inspirada en <span
            class="text-pink-300">Pokémon</span
          >. Aprenderás <strong>arquitectura hexagonal</strong>, <strong
            >TDD</strong
          > y <strong>buenas prácticas de desarrollo</strong> resolviendo retos reales
          de <strong>hotelería</strong> y <strong>ecommerce</strong>. ¡Ideal
          para desarrolladores que buscan dominar <span class="text-green-300"
            >Java backend</span
          > y destacar en la industria!
        </p>
      </section>

      <!-- ¿Por qué gamificar con Pokémon? -->
      <section
        id="gamificacion"
        class="max-w-5xl p-8 mx-auto level-section"
        aria-labelledby="gamificacion-titulo"
      >
        <h2
          id="gamificacion-titulo"
          class="inline-block mb-4 text-3xl font-bold border-b-4 border-red-500 pixel-font glow-title"
        >
          ¿Por qué <span class="text-pink-300">gamificar</span> el aprendizaje de
          Spring Boot?
        </h2>
        <p class="mb-4 text-lg leading-relaxed text-white">
          <strong>Pokémon</strong> es una franquicia que ha marcado generaciones por
          su capacidad de contar historias, incentivar la exploración y el <strong
            >aprendizaje progresivo</strong
          > a través de retos y recompensas. Al gamificar el <strong
            >curso de Spring Boot</strong
          > con esta temática, buscamos:
        </p>
        <ul class="space-y-2 text-lg text-green-300 cherry-list">
          <li>
            Crear una experiencia inmersiva que motive a los desarrolladores a
            avanzar y superar desafíos.
          </li>
          <li>
            Fomentar la curiosidad y el deseo de "capturar" nuevos conocimientos
            y habilidades.
          </li>
          <li>
            Utilizar una narrativa conocida para facilitar la conexión emocional
            y la retención del aprendizaje.
          </li>
          <li>
            Incentivar la colaboración y competencia sana dentro de la
            comunidad.
          </li>
        </ul>
        <p
          class="mt-10 text-lg italic text-yellow-300 underline decoration-pink-500"
        >
          "Aprender es una aventura, y cada línea de código es un paso hacia
          convertirte en un maestro desarrollador."
        </p>
      </section>

      <!-- ¿Por qué ejemplos de hotelería y ecommerce? -->
      <section
        id="ejemplos"
        class="max-w-5xl p-8 mx-auto level-section"
        aria-labelledby="ejemplos-titulo"
      >
        <h2
          id="ejemplos-titulo"
          class="inline-block mb-4 text-3xl font-bold border-b-4 border-green-400 pixel-font glow-title"
        >
          Ejemplos reales de <span class="text-green-300">hotelería</span> y <span
            class="text-blue-300">ecommerce</span
          >
        </h2>
        <p class="mb-4 text-lg leading-relaxed text-white">
          Por mi experiencia elegí los sectores de <strong>hotelería</strong> y <strong
            >ecommerce</strong
          > porque son dominios reales, con <strong
            >casos de uso complejos</strong
          > y variados que permiten aplicar <strong>conceptos técnicos</strong> de
          forma práctica y relevante. Así, aprenderás a resolver problemas reales
          con <span class="text-green-300">Spring Boot</span> y <span
            class="text-yellow-300">arquitectura hexagonal</span
          >.
        </p>
        <ul class="space-y-2 text-lg text-green-300 cherry-list">
          <li>
            La hotelería representa un negocio con múltiples actores, reservas,
            disponibilidad y reglas de negocio que desafían la arquitectura y
            diseño.
          </li>
          <li>
            El ecommerce es un dominio dinámico con flujos de compra,
            inventarios, pagos y logística, ideal para practicar integración y
            pruebas.
          </li>
          <li>
            Ambos ejemplos permiten mostrar cómo aplicar patrones, buenas
            prácticas y arquitectura hexagonal en contextos reales.
          </li>
          <li>
            Facilitan la creación de una narrativa coherente y atractiva para la
            gamificación.
          </li>
        </ul>
        <p
          class="mt-10 text-lg italic text-yellow-300 underline decoration-pink-500"
        >
          "La mejor forma de aprender es construyendo soluciones que reflejen el
          mundo real."
        </p>
      </section>

      <!-- Fundamento pedagógico y narrativa gamificada -->
      <section
        id="fundamento"
        class="max-w-5xl p-8 mx-auto level-section"
        aria-labelledby="fundamento-titulo"
      >
        <h2
          id="fundamento-titulo"
          class="inline-block mb-4 text-3xl font-bold border-b-4 border-purple-500 pixel-font glow-title"
        >
          Fundamento pedagógico y <span class="text-pink-300"
            >narrativa gamificada</span
          >
        </h2>
        <p class="mb-4 text-lg leading-relaxed text-white">
          La <strong>gamificación</strong> no es solo un recurso lúdico, sino una
          <strong>estrategia pedagógica</strong> poderosa que:
        </p>
        <ul class="space-y-2 text-lg text-green-300 cherry-list">
          <li>
            Utiliza la narrativa para crear un contexto emocional y cognitivo
            que facilita la comprensión y retención.
          </li>
          <li>
            Incorpora retos, recompensas y progresión para mantener la
            motivación y el compromiso.
          </li>
          <li>
            Fomenta el aprendizaje activo y la experimentación a través de casos
            prácticos y feedback inmediato.
          </li>
          <li>
            Combina la historia con buenas prácticas de desarrollo para que el
            aprendizaje técnico sea significativo y aplicable.
          </li>
        </ul>
        <p
          class="mt-10 text-lg italic text-yellow-300 underline decoration-pink-500"
        >
          "Contar historias es la forma más antigua y efectiva de enseñar, y la
          tecnología nos permite reinventar esa tradición."
        </p>
      </section>

      <!-- Beneficios para desarrolladores -->
      <section
        id="beneficios"
        class="max-w-5xl p-8 mx-auto level-section"
        aria-labelledby="beneficios-titulo"
      >
        <h2
          id="beneficios-titulo"
          class="inline-block mb-4 text-3xl font-bold border-b-4 border-yellow-300 pixel-font glow-title"
        >
          Beneficios de aprender <span class="text-green-300">Spring Boot</span>
          con gamificación
        </h2>
        <p class="mb-4 text-lg leading-relaxed text-white">
          Al participar en este <strong>curso gamificado de Spring Boot</strong
          >, los desarrolladores obtendrán:
        </p>
        <ul class="space-y-2 text-lg text-green-300 cherry-list">
          <li>
            Dominio práctico de Spring Boot 3.x con arquitectura hexagonal y
            TDD.
          </li>
          <li>
            Experiencia en diseño de software limpio, mantenible y escalable.
          </li>
          <li>
            Comprensión profunda de patrones de diseño y buenas prácticas.
          </li>
          <li>
            Participación en una comunidad activa que comparte conocimiento y
            apoyo.
          </li>
          <li>
            Motivación constante gracias a la narrativa gamificada y retos
            progresivos.
          </li>
        </ul>
        <p
          class="mt-10 text-lg italic text-yellow-300 underline decoration-pink-500"
        >
          ¡Prepárate para transformar tu forma de aprender y desarrollar
          software!
        </p>
      </section>

      <!-- Calendario de liberaciones de milestones -->
      <section
        id="calendario-milestones"
        class="max-w-5xl p-8 mx-auto mb-12 level-section"
        aria-labelledby="calendario-titulo"
      >
        <h2
          id="calendario-titulo"
          class="inline-block mb-6 text-3xl font-bold border-b-4 border-blue-400 pixel-font glow-title"
        >
          📅 Actualizaciones solo fines de semana
        </h2>
        <div class="overflow-x-auto">
          <table
            class="min-w-full overflow-hidden text-sm text-left border-collapse rounded-lg shadow-lg md:text-base"
          >
            <thead
              class="text-white bg-gradient-to-r from-green-400 via-blue-700 to-purple-700"
            >
              <tr>
                <th class="px-3 py-2 font-bold border-b-4 border-blue-300"
                  >OK</th
                >
                <th class="px-3 py-2 font-bold border-b-4 border-blue-300"
                  >Semana</th
                >
                <th class="px-3 py-2 font-bold border-b-4 border-blue-300"
                  >Fechas (Sábado y Domingo)</th
                >
                <th class="px-3 py-2 font-bold border-b-4 border-blue-300"
                  >Actividades principales (según milestone)</th
                >
                <th class="px-3 py-2 font-bold border-b-4 border-blue-300"
                  >Fecha de liberación (domingo)</th
                >
                <th class="px-3 py-2 font-bold border-b-4 border-blue-300"
                  >Versión Milestone</th
                >
              </tr>
            </thead>
            <tbody class="bg-[#181c1f] text-white">
              <tr
                class="font-semibold border-b-2 border-green-400 bg-green-900/60"
              >
                <td class="px-3 py-2 text-center align-middle"
                  ><span class="inline-block w-5 h-5 text-green-300">✔️</span
                  ></td
                >
                <td class="px-3 py-2">1</td>
                <td class="px-3 py-2">18-19 Oct 2025</td>
                <td class="px-3 py-2">Milestone 0: Inicio y versión base</td>
                <td class="px-3 py-2">19 Oct 2025</td>
                <td class="px-3 py-2">0.0.1</td>
              </tr>
              <tr
                class="font-semibold border-b-2 border-green-400 bg-green-900/60"
              >
                <td class="px-3 py-2 text-center align-middle"
                  ><span class="inline-block w-5 h-5 text-green-300">✔️</span
                  ></td
                >
                <td class="px-3 py-2">2</td>
                <td class="px-3 py-2">25-26 Oct 2025</td>
                <td class="px-3 py-2"
                  >Milestone 1: Fundamentos de persistencia y configuración
                  básica (inicio)</td
                >
                <td class="px-3 py-2">26 Oct 2025</td>
                <td class="px-3 py-2">0.0.2</td>
              </tr>
              <tr
                class="font-semibold border-b-2 border-green-400 bg-green-900/60"
              >
                <td class="px-3 py-2 text-center align-middle"
                  ><span class="inline-block w-5 h-5 text-green-300">✔️</span
                  ></td
                >
                <td class="px-3 py-2">3</td>
                <td class="px-3 py-2">1-2 Nov 2025</td>
                <td class="px-3 py-2"
