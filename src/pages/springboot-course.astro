---
// src/pages/springboot-course.astro
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

import {
  weeks,
  blogPosts,
  MILESTONES,
  completedWeeks,
  totalWeeks,
  progressPercent,
  currentLevel,
  lastVersion,
} from "../data/course";

const title = "Curso Gamificado Spring Boot + Kotlin | Arturo López";
const description =
  "Aprende Spring Boot 3.x con Kotlin, arquitectura y TDD. Retos reales de hotelería y ecommerce.";
const pendingWeeks = totalWeeks - completedWeeks;
---

<BaseLayout
  title={title}
  description={description}
  canonical="https://lgzarturo.com/springboot-course"
>
  <!-- ══ HEAD: SEO, OG, fuentes ══════════════════════════════════ -->
  <head>
    <meta
      name="description"
      content="Curso gamificado de Spring Boot con arquitectura, TDD y ejemplos reales de hotelería y ecommerce. Aprende programación con una narrativa inspirada en Pokémon. ¡Únete a la comunidad de desarrolladores!"
    />
    <meta
      name="keywords"
      content="Spring Boot, curso gamificado, arquitectura, TDD, Pokémon, hotelería, ecommerce, comunidad de desarrolladores, programación, Java, backend, buenas prácticas, desarrollo de software"
    />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://lgzarturo.com/springboot-course" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="Curso Gamificado Spring Boot: Aprende con Pokémon, Hotelería y Ecommerce"
    />
    <meta
      property="og:description"
      content="Aprende Spring Boot, arquitectura y TDD con una experiencia gamificada inspirada en Pokémon, hotelería y ecommerce. ¡Únete a la comunidad de desarrolladores!"
    />
    <meta property="og:url" content="https://lgzarturo.com/springboot-course" />
    <meta
      property="og:image"
      content="https://raw.githubusercontent.com/lgzarturo/arthurolg-blog-posts/refs/heads/main/articles/images/el-legado-del-desarrollador.webp"
    />
    <meta
      property="og:image:alt"
      content="Curso Gamificado Spring Boot - Pokémon, Hotelería y Ecommerce"
    />
    <meta property="og:site_name" content="Arturo López Gómez" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Curso Gamificado Spring Boot: Aprende con Pokémon, Hotelería y Ecommerce"
    />
    <meta
      name="twitter:description"
      content="Aprende Spring Boot, arquitectura y TDD con una experiencia gamificada inspirada en Pokémon, hotelería y ecommerce. ¡Únete a la comunidad de desarrolladores!"
    />
    <meta
      name="twitter:image"
      content="https://raw.githubusercontent.com/lgzarturo/arthurolg-blog-posts/refs/heads/main/articles/images/el-legado-del-desarrollador.webp"
    />
    <meta
      name="twitter:image:alt"
      content="Curso Gamificado Spring Boot - Pokémon, Hotelería y Ecommerce"
    />

    <!-- JSON-LD -->
    <script type="application/ld+json" is:raw>
      {
        "@context": "https://schema.org",
        "@type": "Course",
        "name": "Curso Gamificado de Spring Boot: Aprende con Pokémon, Hotelería y Ecommerce",
        "description": "Curso gamificado de Spring Boot con arquitectura, TDD y ejemplos reales de hotelería y ecommerce.",
        "provider": {
          "@type": "Person",
          "name": "Arturo López Gómez",
          "url": "https://lgzarturo.com"
        },
        "image": "https://raw.githubusercontent.com/lgzarturo/arthurolg-blog-posts/refs/heads/main/articles/images/el-legado-del-desarrollador.webp",
        "url": "https://lgzarturo.com/springboot-course"
      }
    </script>

    <!-- Pixelify Sans para títulos retro + JetBrains Mono para código/badges -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Pixelify+Sans:wght@400..700&family=JetBrains+Mono:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <!-- ══ CONTENIDO ════════════════════════════════════════════════ -->
  <Header title="Arturo López" />

  <div class="course-page">
    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="mt-16 hero reveal" aria-labelledby="hero-title">
      <div class="breadcrumb">
        <a href="/#projects">← Laboratorio</a>
        <span aria-hidden="true">/</span>
        <span>Curso SpringBoot + Kotlin</span>
      </div>

      <h1 id="hero-title" class="pixel-font">
        Curso Gamificado de
        <span class="text-green">Spring Boot</span> con
        <span class="text-blue">Arquitectura MVC</span> y
        <span class="text-yellow">TDD</span>
      </h1>

      <p class="hero-sub">
        <strong
          >Aprende Spring Boot, buenas prácticas y arquitectura con TDD</strong
        > en una experiencia única. Vive una <strong
          >historia gamificada inspirada en Pokémon</strong
        >, resolviendo retos reales de hotelería y ecommerce.
      </p>

      <div class="hero-chips">
        <span class="chip chip-live">
          <span class="chip-dot" aria-hidden="true"></span>
          Actualizado cada fin de semana
        </span>
        {
          [
            "Spring Boot 3.x",
            "Kotlin",
            "TDD",
            "MVC Arch",
            "Docker",
            "CI/CD",
          ].map((tag) => <span class="chip">{tag}</span>)
        }
      </div>

      <nav aria-label="Secciones de la página" class="hero-nav">
        <a href="#exp-tracker">Progreso</a>
        <a href="#roadmap">Roadmap</a>
        <a href="#que-es">¿Qué es?</a>
        <a href="#beneficios">Beneficios</a>
        <a href="#blog">Blog</a>
        <a href="#participa">Participar</a>
      </nav>
    </section>

    <!-- ── EXP TRACKER (Pokémon-style) ──────────────────────────── -->
    <section
      id="exp-tracker"
      class="exp-card pixel-border reveal"
      role="region"
      aria-label="Progreso del curso"
    >
      <!-- Stripe de color arriba del card -->
      <div class="exp-stripe" aria-hidden="true"></div>

      <div class="exp-top">
        <div>
          <div class="exp-title pixel-font">🎮 Progreso del entrenamiento</div>
          <div class="exp-flavor mono">
            "Conviértete en un maestro desarrollador"
          </div>
        </div>
        <span class="level-badge mono" aria-label={`Nivel ${currentLevel}`}>
          LVL {currentLevel}
        </span>
      </div>

      <!-- EXP bar clásica Pokémon -->
      <div class="exp-bar-wrap">
        <div class="exp-bar-labels">
          <span class="mono" style="color:var(--text-3)">EXP</span>
          <span class="mono" id="pct-label" style="color:var(--poke-yellow)">
            0 / {totalWeeks} semanas
          </span>
        </div>
        <div
          class="exp-bar-track"
          role="progressbar"
          aria-valuenow={completedWeeks}
          aria-valuemin={0}
          aria-valuemax={totalWeeks}
          aria-label="Semanas completadas"
        >
          <div class="exp-bar-fill" id="exp-fill"></div>
        </div>
      </div>

      <!-- Stats -->
      <div class="stat-grid">
        <div class="stat-cell">
          <div class="stat-val" style="color:var(--poke-yellow)">
            {completedWeeks}
          </div>
          <div class="stat-key">Completadas</div>
        </div>
        <div class="stat-cell">
          <div class="stat-val" style="color:var(--text-3)">{pendingWeeks}</div>
          <div class="stat-key">Pendientes</div>
        </div>
        <div class="stat-cell">
          <div
            class="stat-val mono"
            style="color:var(--poke-green);font-size:20px"
          >
            {lastVersion}
          </div>
          <div class="stat-key">Release</div>
        </div>
      </div>
    </section>

    <!-- ── ROADMAP ───────────────────────────────────────────────── -->
    <section
      id="roadmap"
      class="section-block reveal"
      aria-labelledby="roadmap-title"
    >
      <div class="section-header">
        <h2 id="roadmap-title" class="section-title pixel-font glow-title">
          🗓 Roadmap semanal
        </h2>
        <span class="mono week-count" id="week-count">{totalWeeks} semanas</span
        >
      </div>

      <!-- Gym badge filter: cada milestone es un badge -->
      <div
        class="badge-filter"
        id="badge-filter"
        role="group"
        aria-label="Filtrar por milestone"
      >
        <button class="gym-badge active" data-ms="all" aria-pressed="true">
          <div
            class="gym-badge-icon"
            style="background:#2a2f3a"
            aria-hidden="true"
          >
            🎮
          </div>
          <span class="gym-badge-label mono">Todas</span>
        </button>

        {
          Object.entries(MILESTONES).map(([key, ms]) => {
            const done = weeks.filter((w) => w.ms === key && w.done).length;
            const count = weeks.filter((w) => w.ms === key).length;
            const allDone = done === count;
            return (
              <button
                class="gym-badge"
                data-ms={key}
                aria-pressed="false"
                aria-label={`${ms.label}: ${done} de ${count} completadas`}
              >
                <div
                  class="gym-badge-icon"
                  style={`background:${allDone ? ms.color : "#2a2f3a"};${!allDone ? "filter:grayscale(1);opacity:0.5" : ""}`}
                  aria-hidden="true"
                >
                  {ms.icon}
                </div>
                <span class="gym-badge-label mono">{key}</span>
              </button>
            );
          })
        }
      </div>

      <!-- Las week cards las renderiza JS para soportar filtro + acordeón -->
      <div id="weeks-stack" class="weeks-stack" aria-live="polite"></div>

      <!-- GitHub notice -->
      <div class="gh-notice" role="note">
        <span aria-hidden="true">⚠️</span>
        <span>
          Actualizaciones de calendario y cambios importantes en el{" "}
          <a
            href="https://github.com/users/lgzarturo/projects/12"
            target="_blank"
            rel="noopener noreferrer"
          >
            Project Board de GitHub →
          </a>
        </span>
      </div>
    </section>

    <!-- ── ¿QUÉ ES? ──────────────────────────────────────────────── -->
    <section
      id="que-es"
      class="section-block level-section reveal"
      aria-labelledby="que-es-titulo"
    >
      <h2
        id="que-es-titulo"
        class="pixel-font glow-title section-h2 border-yellow"
      >
        ¿Qué es este <span class="text-blue">curso gamificado</span>?
      </h2>
      <p>
        Este <strong>curso online de Spring Boot</strong> es una experiencia educativa
        innovadora que combina el <strong>aprendizaje técnico</strong> con una
        <strong>narrativa gamificada</strong> inspirada en <span
          class="text-pink">Pokémon</span
        >. Aprenderás <strong>arquitectura MVC</strong>, <strong>TDD</strong> y
        <strong>buenas prácticas de desarrollo</strong> resolviendo retos reales de
        <strong>hotelería</strong> y <strong>ecommerce</strong>. Ideal para
        desarrolladores que buscan dominar <span class="text-green"
          >Java backend</span
        >
        y destacar en la industria.
      </p>
    </section>

    <!-- ── GAMIFICACIÓN ──────────────────────────────────────────── -->
    <section
      id="gamificacion"
      class="section-block level-section reveal"
      aria-labelledby="gamificacion-titulo"
    >
      <h2
        id="gamificacion-titulo"
        class="pixel-font glow-title section-h2 border-red"
      >
        ¿Por qué <span class="text-blue">gamificar</span> el aprendizaje?
      </h2>
      <p class="mb-block">
        <strong>Pokémon</strong> es una franquicia que ha marcado generaciones por
        su capacidad de contar historias, incentivar la exploración y el
        <strong>aprendizaje progresivo</strong> a través de retos y recompensas.
      </p>
      <ul class="poke-list">
        <li>
          Crear una experiencia inmersiva que motive a los desarrolladores a
          avanzar y superar desafíos.
        </li>
        <li>
          Fomentar la curiosidad y el deseo de "capturar" nuevos conocimientos y
          habilidades.
        </li>
        <li>
          Usar una narrativa conocida para facilitar la conexión emocional y la
          retención del aprendizaje.
        </li>
        <li>
          Incentivar la colaboración y competencia sana dentro de la comunidad.
        </li>
      </ul>
      <p class="quote">
        "Aprender es una aventura, y cada línea de código es un paso hacia
        convertirte en un maestro desarrollador."
      </p>
    </section>

    <!-- ── EJEMPLOS REALES ───────────────────────────────────────── -->
    <section
      id="ejemplos"
      class="section-block level-section reveal"
      aria-labelledby="ejemplos-titulo"
    >
      <h2
        id="ejemplos-titulo"
        class="pixel-font glow-title section-h2 border-green"
      >
        Ejemplos de <span class="text-green">hotelería</span> y <span
          class="text-blue">ecommerce</span
        >
      </h2>
      <p class="mb-block">
        Elegí estos sectores porque son dominios reales con <strong
          >casos de uso complejos</strong
        >
        que permiten aplicar conceptos técnicos de forma práctica y relevante.
      </p>
      <ul class="poke-list">
        <li>
          La hotelería: múltiples actores, reservas, disponibilidad y reglas de
          negocio que desafían la arquitectura.
        </li>
        <li>
          El ecommerce: flujos de compra, inventarios, pagos y logística, ideal
          para practicar integración y pruebas.
        </li>
        <li>
          Ambos dominios muestran cómo aplicar patrones y arquitectura MVC en
          contextos reales.
        </li>
        <li>
          Facilitan una narrativa coherente y atractiva para la gamificación.
        </li>
      </ul>
      <p class="quote">
        "La mejor forma de aprender es construyendo soluciones que reflejen el
        mundo real."
      </p>
    </section>

    <!-- ── FUNDAMENTO ────────────────────────────────────────────── -->
    <section
      id="fundamento"
      class="section-block level-section reveal"
      aria-labelledby="fundamento-titulo"
    >
      <h2
        id="fundamento-titulo"
        class="pixel-font glow-title section-h2 border-purple"
      >
        Fundamento pedagógico y <span class="text-blue"
          >narrativa gamificada</span
        >
      </h2>
      <p class="mb-block">
        La <strong>gamificación</strong> no es solo un recurso lúdico, sino una
        <strong>estrategia pedagógica</strong> poderosa que:
      </p>
      <ul class="poke-list">
        <li>
          Usa la narrativa para crear un contexto emocional y cognitivo que
          facilita la comprensión y retención.
        </li>
        <li>
          Incorpora retos, recompensas y progresión para mantener la motivación
          y el compromiso.
        </li>
        <li>
          Fomenta el aprendizaje activo a través de casos prácticos y feedback
          inmediato.
        </li>
        <li>
          Combina historia con buenas prácticas para que el aprendizaje técnico
          sea significativo y aplicable.
        </li>
      </ul>
      <p class="quote">
        "Contar historias es la forma más antigua y efectiva de enseñar, y la
        tecnología nos permite reinventar esa tradición."
      </p>
    </section>

    <!-- ── BENEFICIOS ────────────────────────────────────────────── -->
    <section
      id="beneficios"
      class="section-block reveal"
      aria-labelledby="beneficios-titulo"
    >
      <h2
        id="beneficios-titulo"
        class="pixel-font glow-title section-title border-yellow"
      >
        🏆 Beneficios del curso
      </h2>
      <div class="features-grid">
        {
          [
            {
              icon: "🏗️",
              title: "Arquitectura MVC",
              desc: "Diseño desacoplado con capas y features. Tu lógica de negocio sin depender de Spring.",
            },
            {
              icon: "🧪",
              title: "TDD real",
              desc: "Red → Green → Refactor con Testcontainers. Tests que prueban comportamiento, no implementación.",
            },
            {
              icon: "🔐",
              title: "Spring Security",
              desc: "JWT, roles, CORS y rate limiting bien configurados para producción.",
            },
            {
              icon: "🚀",
              title: "Deploy real",
              desc: "Actuator, Docker, CI/CD con cobertura >85% y monitoreo con Sentry.",
            },
            {
              icon: "📡",
              title: "Mensajería",
              desc: "Eventos de dominio, Kafka/RabbitMQ y caching con Spring Cache.",
            },
            {
              icon: "🏨",
              title: "Casos reales",
              desc: "Hotelería y ecommerce: reservas, inventario, pagos y flujos complejos.",
            },
          ].map((f) => (
            <div class="feat-card pixel-border-sm">
              <div class="feat-icon" aria-hidden="true">
                {f.icon}
              </div>
              <div class="feat-title">{f.title}</div>
              <div class="feat-desc">{f.desc}</div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- ── BLOG ──────────────────────────────────────────────────── -->
    <section
      id="blog"
      class="section-block reveal"
      aria-labelledby="blog-titulo"
    >
      <h2 id="blog-titulo" class="pixel-font glow-title section-title">
        📝 Del blog
      </h2>
      <div class="blog-stack">
        {
          blogPosts.map((post) => (
            <a
              href={post.ready ? post.href : undefined}
              class:list={["blog-card", { "blog-card--ready": post.ready }]}
              aria-disabled={!post.ready}
            >
              <span
                class="blog-dot"
                style={`background:${post.tagColor}`}
                aria-hidden="true"
              />
              <div class="blog-content">
                <div class="blog-cat mono" style={`color:${post.tagColor}`}>
                  {post.tag}
                </div>
                <div class="blog-title">{post.title}</div>
                <div class="blog-desc">{post.desc}</div>
              </div>
              <span class="blog-status mono">
                {post.ready ? "Leer →" : "Pronto"}
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ── PARTICIPA / CTA ───────────────────────────────────────── -->
    <section
      id="participa"
      class="section-block cta-section reveal"
      aria-labelledby="participa-titulo"
    >
      <div class="cta-card pixel-border">
        <h2 id="participa-titulo" class="pixel-font glow-h1 cta-title">
          ¡Únete a la aventura! 🎮
        </h2>
        <p class="cta-sub">
          El repositorio es público. Clona, forkea, abre un PR y forma parte de
          la comunidad. Únete a la wiki, descarga el código, participa en retos
          semanales y ayuda a otros.
        </p>
        <div class="warning-box" role="note">
          <span aria-hidden="true">⚠️</span>
          <span>
            Actualizaciones, retrasos y cambios de calendario en el{" "}
            <a
              href="https://github.com/users/lgzarturo/projects/12"
              target="_blank"
              rel="noopener noreferrer"
            >
              Project Board de GitHub
            </a>. ¡Activa las notificaciones!
          </span>
        </div>
        <div class="cta-buttons">
          <a
            href="https://github.com/lgzarturo/springboot-course"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-retro"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
              ></path>
            </svg>
            Ver en GitHub
          </a>
          <a
            href="https://github.com/lgzarturo/springboot-course/wiki"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            📖 Wiki del proyecto
          </a>
        </div>
      </div>
    </section>
  </div><!-- /course-page -->

  <Footer />
</BaseLayout>

<style is:global>
  /* ── Design tokens ──────────────────────────────────────────── */
  :root {
    /* Colores base del sitio (dark by default, igual que tu sitio) */
    --bg: #181c1f;
    --surface: #1e2328;
    --surface-2: #252b31;
    --border: #2e353d;
    --border-2: #3d4752;
    --text: #e8edf2;
    --text-2: #8b98a8;
    --text-3: #5a6472;

    /* Paleta Pokémon */
    --poke-yellow: #f59e0b;
    --poke-red: #ef4444;
    --poke-blue: #3b82f6;
    --poke-green: #2aff6a;
    --poke-purple: #8b5cf6;
    --poke-pink: #ec4899;
    --poke-orange: #f97316;
    --poke-cyan: #00e0ff;

    /* Shadows & radii */
    --shadow: 0 1px 3px rgba(0, 0, 0, 0.4), 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.5), 0 2px 4px rgba(0, 0, 0, 0.3);
    --radius: 10px;
    --radius-sm: 6px;
  }

  /* ── Fuentes ────────────────────────────────────────────────── */
  .pixel-font {
    font-family: "Pixelify Sans", cursive;
    font-optical-sizing: auto;
    letter-spacing: 1px;
  }
  .mono {
    font-family: "JetBrains Mono", monospace;
  }

  /* ── Colores de texto Pokémon ───────────────────────────────── */
  .text-green {
    color: var(--poke-green);
  }
  .text-blue {
    color: var(--poke-cyan);
  }
  .text-yellow {
    color: var(--poke-yellow);
  }
  .text-pink {
    color: var(--poke-pink);
  }
  .text-purple {
    color: var(--poke-purple);
  }

  /* ── Glow effects ───────────────────────────────────────────── */
  .glow-h1 {
    color: var(--poke-blue);
    text-shadow:
      0 0 8px var(--poke-cyan),
      0 0 20px rgba(0, 224, 255, 0.3);
  }
  .glow-title {
    color: var(--poke-green);
    text-shadow:
