---
// src/pages/index.astro
import { Image } from "astro:assets";
import aboutMeDay from "../assets/images/arturo-lopez-day.png";
import aboutMeNight from "../assets/images/arturo-lopez-night.png";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionColumn from "../components/SectionColumn.astro";
import SectionTitle from "../components/SectionTitle.astro";
---

<BaseLayout title="Recursos y aprendizaje — Arturo López Gómez"
            description="Repositorios de GitHub, notas técnicas y proyectos en desarrollo. Spring Boot, Python, PHP, SEO y más."
            canonical="https://lgzarturo.com/recursos">
  <Header title="Arturo López" />
  <main>
    <SectionColumn
      id="sobre-mi"
      title="Hola!, Soy Arturo López"
      accent="bg-gray-100 outline-dashed outline-stone-100 outline-offset-0"
    >
      <div class="space-y-4 relative">
        <span
          class="absolute -top-30 -left-24 text-gray-400 font-extrabold text-9xl opacity-20"
          >&lt;\&gt;</span
        >
        <p>
          Un apasionado Líder Técnico con más de 15 años de experiencia en el
          desarrollo de software, especializado en Java y Spring Boot. A lo
          largo de mi carrera, he tenido la oportunidad de liderar equipos
          talentosos y trabajar en proyectos desafiantes que abarcan desde
          aplicaciones empresariales hasta soluciones web modernas utilizando
          Next.js.
        </p>

        <p>
          Mi enfoque se centra en la creación de arquitecturas robustas y
          escalables, promoviendo las mejores prácticas de desarrollo y
          fomentando una cultura de colaboración y aprendizaje continuo dentro
          de los equipos que lidero. Además, cuento con experiencia en DevOps,
          CI/CD y despliegue en la nube, lo que me permite asegurar que las
          soluciones que entregamos no solo sean funcionales, sino también
          eficientes y mantenibles.
        </p>
      </div>
      <div class="relative mt-16" slot="content">
        <div
          class="w-full h-96 bg-gradient-to-br from-blue-100 to-purple-100 rounded-2xl flex items-center justify-center"
        >
          <picture>
            <!-- Imagen para pantallas grandes -->
            <source
              srcset={aboutMeDay.src}
              media="(min-width: 1024px)"
              type="image/png"
            />
            <!-- Imagen para pantallas móviles -->
            <source
              srcset={aboutMeNight.src}
              media="(max-width: 1023px)"
              type="image/png"
            />
            <Image
              src={aboutMeDay}
              alt="Sobre mí - Arturo López Gómez"
              class="absolute inset-0 w-full h-full object-cover object-center rounded-2xl -m-5"
              loading="eager"
            />
          </picture>
        </div>
      </div>
    </SectionColumn>
    <SectionTitle title="Recursos para aprendizaje y notas">
      <!-- Sección de recursos de aprendizaje -->
      <section
        id="recursos-aprendizaje"
        class="mt-8 bg-gradient-to-br from-purple-50 to-blue-50 border-2 border-purple-200 rounded-2xl p-6 shadow-lg"
      >
        <div class="mb-6 flex items-center gap-3">
          <span
            class="inline-block px-3 py-1 bg-purple-200 text-purple-800 font-bold rounded-full text-sm"
            ># recursos-aprendizaje</span
          >
          <span class="text-gray-500"
            >Accede fácilmente a mis repositorios de notas y ejemplos</span
          >
        </div>
        <div class="grid gap-6 md:grid-cols-2 mt-4">
          <!-- Card 1 -->
          <a href="https://github.com/lgzarturo/learning-resources" target="_blank" rel="noopener" class="bg-white p-6 rounded-2xl shadow-sm border border-purple-100 hover:shadow-md hover:border-purple-300 transition-all group flex flex-col h-full">
            <div class="flex items-center justify-between mb-3">
              <h4 class="font-bold text-blue-700 text-lg group-hover:text-blue-800">Recursos de programación</h4>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-500 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.236 1.84 1.236 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.3-5.467-1.334-5.467-5.93 0-1.31.468-2.38 1.236-3.22-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23a11.52 11.52 0 013-.404c1 .005 2 .138 3 .404 2.291-1.552 3.297-1.23 3.297-1.23 .653 1.653 .242 2.873 .118 3.176 .77 .84 1.235 1.91 1.235 3.22 0 4.61 -2.807 5.625 -5.479 5.921 .43 .372 .823 1 .823 2v2.972c0 .319 .218 .694 .825 .576C20.565 21.795 24 17.297 24 12c0 -6.63 -5.37 -12 -12 -12z"></path></svg>
            </div>
            <p class="text-gray-600 text-sm mb-4 flex-grow">Repositorio donde comparto recursos, notas y enlaces útiles para aprender. Ideal para desarrolladores que buscan material de apoyo.</p>
            <span class="text-blue-500 text-sm font-medium flex items-center gap-1 group-hover:gap-2 transition-all">Ver repositorio <span aria-hidden="true">&rarr;</span></span>
          </a>

          <!-- Card 2 -->
          <a href="https://github.com/lgzarturo/practice-examples" target="_blank" rel="noopener" class="bg-white p-6 rounded-2xl shadow-sm border border-purple-100 hover:shadow-md hover:border-purple-300 transition-all group flex flex-col h-full">
            <div class="flex items-center justify-between mb-3">
              <h4 class="font-bold text-blue-700 text-lg group-hover:text-blue-800">Patrones de diseño en Java</h4>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-500 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.236 1.84 1.236 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.3-5.467-1.334-5.467-5.93 0-1.31.468-2.38 1.236-3.22-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23a11.52 11.52 0 013-.404c1 .005 2 .138 3 .404 2.291-1.552 3.297-1.23 3.297-1.23 .653 1.653 .242 2.873 .118 3.176 .77 .84 1.235 1.91 1.235 3.22 0 4.61 -2.807 5.625 -5.479 5.921 .43 .372 .823 1 .823 2v2.972c0 .319 .218 .694 .825 .576C20.565 21.795 24 17.297 24 12c0 -6.63 -5.37 -12 -12 -12z"></path></svg>
            </div>
            <p class="text-gray-600 text-sm mb-4 flex-grow">Presento los patrones de diseño y su implementación en Java, con ejemplos prácticos y explicaciones claras para arquitecturas robustas.</p>
            <span class="text-blue-500 text-sm font-medium flex items-center gap-1 group-hover:gap-2 transition-all">Ver repositorio <span aria-hidden="true">&rarr;</span></span>
          </a>

          <!-- Card 3 -->
          <a href="https://github.com/lgzarturo/productividad" target="_blank" rel="noopener" class="bg-white p-6 rounded-2xl shadow-sm border border-purple-100 hover:shadow-md hover:border-purple-300 transition-all group flex flex-col h-full">
            <div class="flex items-center justify-between mb-3">
              <h4 class="font-bold text-blue-700 text-lg group-hover:text-blue-800">Productividad Developer</h4>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-500 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.236 1.84 1.236 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.3-5.467-1.334-5.467-5.93 0-1.31.468-2.38 1.236-3.22-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23a11.52 11.52 0 013-.404c1 .005 2 .138 3 .404 2.291-1.552 3.297-1.23 3.297-1.23 .653 1.653 .242 2.873 .118 3.176 .77 .84 1.235 1.91 1.235 3.22 0 4.61 -2.807 5.625 -5.479 5.921 .43 .372 .823 1 .823 2v2.972c0 .319 .218 .694 .825 .576C20.565 21.795 24 17.297 24 12c0 -6.63 -5.37 -12 -12 -12z"></path></svg>
            </div>
            <p class="text-gray-600 text-sm mb-4 flex-grow">Repositorio que recopila herramientas, dotfiles y técnicas que utilizo a diario para mejorar mi productividad técnica.</p>
            <span class="text-blue-500 text-sm font-medium flex items-center gap-1 group-hover:gap-2 transition-all">Ver repositorio <span aria-hidden="true">&rarr;</span></span>
          </a>

          <!-- Card 4 -->
          <a href="https://github.com/lgzarturo/notes" target="_blank" rel="noopener" class="bg-white p-6 rounded-2xl shadow-sm border border-purple-100 hover:shadow-md hover:border-purple-300 transition-all group flex flex-col h-full">
            <div class="flex items-center justify-between mb-3">
              <h4 class="font-bold text-blue-700 text-lg group-hover:text-blue-800">Notas de Software</h4>
              <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-500 transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.236 1.84 1.236 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.3-5.467-1.334-5.467-5.93 0-1.31.468-2.38 1.236-3.22-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23a11.52 11.52 0 013-.404c1 .005 2 .138 3 .404 2.291-1.552 3.297-1.23 3.297-1.23 .653 1.653 .242 2.873 .118 3.176 .77 .84 1.235 1.91 1.235 3.22 0 4.61 -2.807 5.625 -5.479 5.921 .43 .372 .823 1 .823 2v2.972c0 .319 .218 .694 .825 .576C20.565 21.795 24 17.297 24 12c0 -6.63 -5.37 -12 -12 -12z"></path></svg>
            </div>
            <p class="text-gray-600 text-sm mb-4 flex-grow">Notas y apuntes sobre diseño de sistemas, arquitectura, DevOps y temas misceláneos de ingeniería de software.</p>
            <span class="text-blue-500 text-sm font-medium flex items-center gap-1 group-hover:gap-2 transition-all">Ver repositorio <span aria-hidden="true">&rarr;</span></span>
          </a>
        </div>
      </section>
    </SectionTitle>

    <SectionTitle title="Radar Tecnológico y Stack" accent="bg-white">
      <div class="grid md:grid-cols-3 gap-8 text-left" slot="content">
        <!-- Adopt -->
        <div class="bg-gray-50 rounded-2xl p-6 border-t-4 border-blue-500 shadow-sm hover:shadow-md transition-shadow">
          <h4 class="text-lg font-bold text-gray-900 mb-2 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-blue-500"></span> Core (Adopción)
          </h4>
          <p class="text-sm text-gray-600 mb-4">Tecnologías en las que confío para entornos de producción y escalabilidad.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-medium border border-blue-200">Java / Spring Boot</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-medium border border-blue-200">AWS / Docker</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-medium border border-blue-200">PostgreSQL</span>
            <span class="px-3 py-1 bg-blue-100 text-blue-800 rounded-full text-xs font-medium border border-blue-200">Microservicios</span>
          </div>
        </div>

        <!-- Trial -->
        <div class="bg-gray-50 rounded-2xl p-6 border-t-4 border-green-500 shadow-sm hover:shadow-md transition-shadow">
          <h4 class="text-lg font-bold text-gray-900 mb-2 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-green-500"></span> Trial (Exploración)
          </h4>
          <p class="text-sm text-gray-600 mb-4">Herramientas que estoy probando o utilizando en proyectos secundarios con excelentes resultados.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-xs font-medium border border-green-200">Next.js / React</span>
            <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-xs font-medium border border-green-200">Python / IA</span>
            <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-xs font-medium border border-green-200">Astro</span>
            <span class="px-3 py-1 bg-green-100 text-green-800 rounded-full text-xs font-medium border border-green-200">Kotlin</span>
          </div>
        </div>

        <!-- Assess/Hold -->
        <div class="bg-gray-50 rounded-2xl p-6 border-t-4 border-gray-400 shadow-sm hover:shadow-md transition-shadow">
          <h4 class="text-lg font-bold text-gray-900 mb-2 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-gray-400"></span> Hold (Mantenimiento)
          </h4>
          <p class="text-sm text-gray-600 mb-4">Tecnologías con las que tengo gran experiencia pero que ya no elijo para proyectos nuevos.</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-gray-200 text-gray-800 rounded-full text-xs font-medium border border-gray-300">PHP Legado</span>
            <span class="px-3 py-1 bg-gray-200 text-gray-800 rounded-full text-xs font-medium border border-gray-300">Grails</span>
            <span class="px-3 py-1 bg-gray-200 text-gray-800 rounded-full text-xs font-medium border border-gray-300">Vanilla JS (Complejo)</span>
          </div>
        </div>
      </div>
    </SectionTitle>

    <SectionTitle
      title="Proyectos en marcha"
      accent="bg-gray-100 outline-dashed outline-stone-100 outline-offset-0"
    >
      <section id="proyectos-en-marcha" class="mt-8">
        <div class="mb-6 flex items-center gap-3">
          <span
            class="inline-block px-3 py-1 bg-green-200 text-green-800 font-bold rounded-full text-sm"
            ># proyectos-en-marcha</span
          >
          <span class="text-gray-500"
            >Ideas y herramientas que se están cocinando en el laboratorio</span
          >
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          <!-- Proyecto 1 -->
          <a
            href="https://miraeljuego.com/?utm_source=lgzarturo_cv&utm_medium=referral&utm_campaign=about_me"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white rounded-2xl shadow-lg border-t-4 border-purple-400 p-6 flex flex-col hover:scale-105 transition-transform duration-200 cursor-pointer"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">🎮</span>
              <h3 class="text-lg font-bold text-purple-700">miraeljuego.com</h3>
            </div>
            <p class="text-gray-700">
              Blog automatizado de noticias de videojuegos, análisis y
              tendencias del mundo gamer.
            </p>
          </a>
          <!-- Proyecto 2 -->
          <a
            href="https://devtools.lgzarturo.com/?utm_source=lgzarturo_cv&utm_medium=referral&utm_campaign=about_me"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white rounded-2xl shadow-lg border-t-4 border-yellow-400 p-6 flex flex-col hover:scale-105 transition-transform duration-200 cursor-pointer"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">🛠️</span>
              <h3 class="text-lg font-bold text-yellow-700">
                Herramientas SEO
              </h3>
            </div>
            <p class="text-gray-700">
              Conjunto de herramientas especializadas en SEO pensadas para
              facilitar el trabajo técnico de los desarrolladores web.
            </p>
          </a>
          <!-- Proyecto 3 -->
          <a
            href="https://task-manager.lgzarturo.com/?utm_source=lgzarturo_cv&utm_medium=referral&utm_campaign=about_me"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white rounded-2xl shadow-lg border-t-4 border-indigo-400 p-6 flex flex-col hover:scale-105 transition-transform duration-200 cursor-pointer"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">🚀</span>
              <h3 class="text-lg font-bold text-indigo-700">
                Personal manager
              </h3>
            </div>
            <p class="text-gray-700">
              Proyecto para automatizar flujos de trabajo y mejorar la
              productividad personal.
            </p>
          </a>

          <!-- Proyecto 4 -->
          <a
            href="#"
            class="bg-white rounded-2xl shadow-lg border-t-4 border-blue-400 p-6 flex flex-col hover:scale-105 transition-transform duration-200 cursor-not-allowed hover:grayscale"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">💼</span>
              <h3 class="text-lg font-bold text-blue-700">joobslot.com</h3>
            </div>
            <p class="text-gray-700">
              Herramienta para promocionar posiciones de empleo de forma
              eficiente y atractiva para empresas y candidatos.
            </p>
          </a>
          <!-- Proyecto 5 -->
          <a
            href="#"
            class="bg-white rounded-2xl shadow-lg border-t-4 border-pink-400 p-6 flex flex-col hover:scale-105 transition-transform duration-200 cursor-not-allowed hover:grayscale"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">🤖</span>
              <h3 class="text-lg font-bold text-pink-700">
                Automatizaciones con IA
              </h3>
            </div>
            <p class="text-gray-700">
              Ideas y experimentos de automatización de flujos de trabajo
              utilizando inteligencia artificial y herramientas modernas.
            </p>
          </a>
          <!-- Proyecto 6 -->
          <a
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white rounded-2xl shadow-lg border-t-4 border-green-400 p-6 flex flex-col hover:scale-105 transition-transform duration-200 cursor-not-allowed hover:grayscale"
          >
            <div class="flex items-center gap-2 mb-2">
              <span class="text-2xl">🏨</span>
              <h3 class="text-lg font-bold text-green-700">
                visitapormexico.com
              </h3>
            </div>
            <p class="text-gray-700">
              Portal para promocionar hoteles y destinos turísticos de México,
              enriquecido con historias de viajes y experiencias.
            </p>
          </a>
        </div>
      </section>
    </SectionTitle>
  </main>
  <Footer />
</BaseLayout>
